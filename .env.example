# Root Docker Compose environment.
# Copy this file to .env before running docker compose if you want to override defaults.

POSTGRES_DB=job_tracker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

BACKEND_PORT=8080
FRONTEND_PORT=5173

# Use a unique 32+ character value for anything beyond local development.
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-characters

APP_SEED_DEMO_DATA=true
APP_OFFLINE_MODE=false
APP_CORS_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*
GMAIL_AUTO_SYNC_DELAY_MS=300000

# Containerized browser autofill is disabled by default because it is designed
# to launch a local browser session on the host machine.
APP_WORKDAY_AUTOFILL_ENABLED=false

# Optional OAuth/integration settings.
APP_GOOGLE_CLIENT_ID=
APP_GOOGLE_CLIENT_SECRET=
APP_GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/integrations/google/callback
APP_GITHUB_CLIENT_ID=
APP_GITHUB_CLIENT_SECRET=
CLOUD_BACKUP_UPLOAD_URL=
CLOUD_BACKUP_API_KEY=
