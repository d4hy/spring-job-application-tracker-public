# Environment Variables Template
# Copy this to .env and fill in your values
# Load with: export $(cat .env | xargs)
# Spring also auto-loads backend/.env via spring.config.import

# ========== JWT CONFIGURATION ==========
JWT_SECRET=your-very-secure-random-string-minimum-32-characters-long

# ========== GOOGLE OAUTH2 ==========
APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
APP_GOOGLE_CLIENT_SECRET=your-google-client-secret
APP_GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/integrations/google/callback

# ========== GITHUB OAUTH2 ==========
APP_GITHUB_CLIENT_ID=your-github-client-id
APP_GITHUB_CLIENT_SECRET=your-github-client-secret

# ========== DATABASE CONFIGURATION ==========
# DB profile: h2 or postgres
APP_DB_PROFILE=h2

# For PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/job_tracker
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Alternative: Remote PostgreSQL
# DB_URL=jdbc:postgresql://prod-db-server.example.com:5432/job_tracker
# DB_USERNAME=job_tracker_user
# DB_PASSWORD=remote_password

# ========== APPLICATION CONFIGURATION ==========
SERVER_PORT=8080
GMAIL_AUTO_SYNC_DELAY_MS=300000
FRONTEND_BASE_URL=http://localhost:5173
FRONTEND_AUTO_OPEN=true
APP_SEED_DEMO_DATA=true
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080
CLOUD_BACKUP_UPLOAD_URL=
CLOUD_BACKUP_API_KEY=
APP_WORKDAY_AUTOFILL_ENABLED=true
APP_WORKDAY_AUTOFILL_NODE_CMD=node
APP_WORKDAY_AUTOFILL_SCRIPT_PATH=../frontend/scripts/workday-autofill.mjs

# ========== LOGGING ==========
LOG_LEVEL=INFO

